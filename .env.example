# Copy to .env and fill in required values
# Required fields have no default value (marked REQUIRED)

# =============================================================================
# Qdrant
# =============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=                     # empty = no auth (dev only)

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=raguser
POSTGRES_PASSWORD=changeme           # REQUIRED — change before use
POSTGRES_DB=ragdb

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# MinIO
# =============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme         # REQUIRED — change before use
MINIO_BUCKET_DOCUMENTS=documents
MINIO_SECURE=false                   # true in production (TLS)

# =============================================================================
# Embedding
# =============================================================================
EMBEDDING_PROVIDER=e5_large          # e5_large | bge_m3 | qwen3
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large
EMBEDDING_DEVICE=cpu                 # cpu | cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_TOKENS=512
HF_HOME=./models                     # local model cache — never committed

# =============================================================================
# Chunking
# =============================================================================
CHUNKING_CHUNK_SIZE=400              # tokens
CHUNKING_CHUNK_OVERLAP=60            # 15% of 400

# =============================================================================
# LLM (vLLM — self-hosted)
# =============================================================================
VLLM_API_URL=http://localhost:8001/v1
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# =============================================================================
# Application
# =============================================================================
RAG_LOG_LEVEL=INFO
